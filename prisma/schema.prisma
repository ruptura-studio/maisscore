generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  name        String
  description String?
  price       Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  orders      Order[]

  @@map("products")
}

model Lead {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String?
  phone              String    @unique
  email              String?
  channel            String?
  status             String    @default("novo")
  companyName        String?   @map("company_name")
  leadType           String?   @map("lead_type")
  checkoutStep       Int?      @map("checkout_step")
  birthDate          DateTime? @map("birth_date") @db.Timestamptz
  addressStreet      String?   @map("address_street")
  addressNumber      String?   @map("address_number")
  addressComplement  String?   @map("address_complement")
  addressNeighborhood String?  @map("address_neighborhood")
  addressCity        String?   @map("address_city")
  addressState       String?   @map("address_state")
  addressZip         String?   @map("address_zip")
  civilStatus        String?   @map("civil_status")
  profession         String?
  identityDocument   String?   @map("identity_document")
  responsibleName    String?   @map("responsible_name")
  responsibleCpf     String?   @map("responsible_cpf")
  utmSource          String?   @map("utm_source")
  utmMedium          String?   @map("utm_medium")
  utmCampaign        String?   @map("utm_campaign")
  utmContent         String?   @map("utm_content")
  utmTerm            String?   @map("utm_term")
  trafficTemperature String    @default("cold") @map("traffic_temperature")
  currentTemperature String?   @map("current_temperature")  // temperatura atual (pode mudar durante atendimento)
  coraTemperature    String?   @map("cora_temperature")     // temperatura classificada pela Cora na triagem
  objetivo           String?                                // para que quer limpar o nome
  tempoEndividado    String?   @map("tempo_endividado")     // quanto tempo está com dívida
  valorDivida        String?   @map("valor_divida")         // faixa de valor da dívida
  estagioNegociacao  String?   @map("estagio_negociacao")   // se já tentou negociar
  cpf                String?                                // CPF capturado em conversa ou checkout
  cnpj               String?                                // CNPJ capturado em conversa ou checkout
  isClient           Boolean   @default(false) @map("is_client") // se tem compra confirmada
  acquisition        String?                                // produto adquirido (ex: limpa_cpf, limpa_cnpj)
  acquisitionValue   Int?      @map("acquisition_value")   // valor pago em centavos
  notionId           String?   @map("notion_id")
  crmId              String?   @map("crm_id")
  stage              String?   @default("lead") @map("stage")
  pendingAction      String?   @map("pending_action")
  reentryCount       Int       @default(0) @map("reentry_count")
  lastInteractionAt  DateTime? @map("last_interaction_at") @db.Timestamptz
  convertedAt        DateTime? @map("converted_at") @db.Timestamptz
  lossReason         String?   @map("loss_reason")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  orders             Order[]
  nurtureLog         NurtureLog[]
  leadEvents         LeadEvent[]
  checkoutEvents     CheckoutEvent[]
  onboardingHandoffs OnboardingHandoff[]

  @@map("leads")
}

model Order {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId       String   @map("lead_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  document     String?
  documentType String?  @map("document_type")
  status       String   @default("pendente")
  pricePaid    Int      @map("price_paid")
  discount     Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  lead         Lead     @relation(fields: [leadId], references: [id])
  product      Product  @relation(fields: [productId], references: [id])
  payment      Payment?
  process      Process?
  onboardingDocuments OnboardingDocument[]
  onboardingHandoffs  OnboardingHandoff[]

  @@map("orders")
}

model Payment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String    @unique @map("order_id") @db.Uuid
  asaasId         String?   @unique @map("asaas_id")
  method          String?
  status          String    @default("pending")
  amount          Int
  pixKey          String?   @map("pix_key")
  pixExpiresAt    DateTime? @map("pix_expires_at") @db.Timestamptz
  boletoUrl       String?   @map("boleto_url")
  boletoExpiresAt DateTime? @map("boleto_expires_at") @db.Timestamptz
  remoteIp        String?   @map("remote_ip")
  confirmedAt     DateTime? @map("confirmed_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  order           Order     @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Process {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String    @unique @map("order_id") @db.Uuid
  status    String    @default("aguardando_inicio")
  stage     String?
  startedAt DateTime? @map("started_at") @db.Timestamptz
  cleanedAt DateTime? @map("cleaned_at") @db.Timestamptz
  proofUrl  String?   @map("proof_url")
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  order     Order     @relation(fields: [orderId], references: [id])

  @@map("processes")
}

model OnboardingDocument {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String    @map("order_id") @db.Uuid
  itemKey     String    @map("item_key")
  label       String
  status      String    @default("pending")
  storagePath String?   @map("storage_path")
  fileUrl     String?   @map("file_url")
  receivedAt  DateTime? @map("received_at") @db.Timestamptz
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  order       Order     @relation(fields: [orderId], references: [id])

  @@map("onboarding_documents")
}

model OnboardingHandoff {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId         String    @map("lead_id") @db.Uuid
  orderId        String    @unique @map("order_id") @db.Uuid
  status         String    @default("ready")
  checklistStatus String    @default("complete") @map("checklist_status")
  checklistSummary String?  @map("checklist_summary")
  missingItems   String?    @map("missing_items")
  processStage   String?    @map("process_stage")
  crmSyncStatus  String?    @map("crm_sync_status")
  routedAt       DateTime?  @map("routed_at") @db.Timestamptz
  handoffSentAt  DateTime?  @map("handoff_sent_at") @db.Timestamptz
  notes          String?
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  lead           Lead       @relation(fields: [leadId], references: [id])
  order          Order      @relation(fields: [orderId], references: [id])

  @@map("onboarding_handoffs")
}

model AbandonedCheckout {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String?
  email         String?
  phone         String?
  document      String?
  documentType  String?  @map("document_type")
  product       String?
  paymentMethod String?  @map("payment_method")
  installments  Int?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("abandoned_checkouts")
}

model NurtureLog {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId  String   @map("lead_id") @db.Uuid
  channel String
  type    String
  message String?
  sentAt  DateTime @default(now()) @map("sent_at") @db.Timestamptz
  status  String   @default("sent")
  lead    Lead     @relation(fields: [leadId], references: [id])

  @@map("nurture_log")
}

model LeadEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  type      String   // 'lead_capturado' | 'triagem_completa' | 'checkout_enviado' | 'pagamento_confirmado' | 'posvendas_iniciado' | 'perdido'
  value     String?  // valor livre para contexto adicional
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  lead      Lead     @relation(fields: [leadId], references: [id])

  @@map("lead_events")
}

model CheckoutEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  type      String   // 'url_gerada' | 'url_enviada' | 'link_clicado' | 'pagamento_confirmado' | 'abandonado'
  metadata  String?  // JSON livre (ex: produto, valor, método)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  lead      Lead     @relation(fields: [leadId], references: [id])

  @@map("checkout_events")
}

model MessageTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   @unique                  // ex: 'cora_greeting', 'fernanda_cold_start'
  flow      String                            // ex: 'cora_screening', 'cold_lead', 'posvendas'
  step      Int                               // ordem dentro do fluxo (1, 2, 3...)
  content   String                            // texto com variáveis: {first_name}, {checkout_url}
  variables String[]                          // lista das variáveis: ['first_name']
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("message_templates")
}
